```
# Build outputs
/build/
/bin/
/gen/
/obj/

# Generated files
R.java
R.class

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Android Studio
/proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
/captures/

# IntelliJ IDEA artifacts
/out/

# Keystore files
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild/

# Native gradle plugin for SDL support
.gradle/native/
```
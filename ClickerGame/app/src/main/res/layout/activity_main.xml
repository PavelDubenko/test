<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:id="@+id/scoreText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Счёт: 0"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/clickPowerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Сила клика: 1"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/autoClickerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Авто-кликеры: 0"
        android:textSize="18sp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/clickButton"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:text="КЛИК!"
        android:textSize="24sp"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/upgradeButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Улучшить клик (10)"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/autoClickerButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Купить авто-кликер (50)"/>

</LinearLayout>
